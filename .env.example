# VNShop — Environment configuration
#
# Copy this file to `.env` and fill in any values you want to override.
# Compose reads `.env` automatically. `.env` is gitignored; `.env.example` is
# the canonical, committed template.
#
# Defaults below match `docker compose --profile apps up` for a local dev box.
# Production overrides go through the same names but resolve to real hostnames
# and secrets sourced from your platform's secret manager.

# ---------------------------------------------------------------------------
# Frontend (Vite, baked into the SPA bundle at `docker compose build frontend`)
# ---------------------------------------------------------------------------
# These flow into Vite as VITE_* and are inlined into dist/. Browsers reach the
# gateway and Keycloak directly, so the URLs must be browser-resolvable
# (NOT in-network names like `api-gateway` or `keycloak`).
VITE_API_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8085
VITE_KEYCLOAK_REALM=vnshop
VITE_KEYCLOAK_CLIENT_ID=vnshop-web

# ---------------------------------------------------------------------------
# Gateway CORS (BE-7)
# ---------------------------------------------------------------------------
# Comma-separated allowed origins. Local default covers the nginx-served SPA
# and the `vite dev` preview port. In production lock to the canonical origin.
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Infrastructure Credentials
# ---------------------------------------------------------------------------
# Override these in production. Local-dev defaults match docker-compose.yml.
DB_PASSWORD=vnshop
REDIS_PASSWORD=vnshop123

# ---------------------------------------------------------------------------
# Optional: Keycloak admin credentials
# ---------------------------------------------------------------------------
# Default `admin/admin` is fine for local dev. Override in any shared env.
# KEYCLOAK_ADMIN_USERNAME=admin
# KEYCLOAK_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Database passwords (CHANGE IN PRODUCTION)
# ---------------------------------------------------------------------------
# Shared password for all per-service postgres instances.
POSTGRES_PASSWORD=vnshop123
# Password for the TimescaleDB monitoring database.
MONITORING_DB_PASSWORD=monitoring
# MongoDB root password (used by mongo container and notification-service).
MONGO_ROOT_PASSWORD=vnshop123

# ---------------------------------------------------------------------------
# Object storage (product images, review photos, invoice PDFs)
# ---------------------------------------------------------------------------
# Two backends are wire-compatible: Cloudflare R2 (production) and MinIO
# (local-dev, runs as a sibling container). The Java services use the AWS S3
# SDK against either. Default values below resolve to the in-network MinIO.
#
# To switch to R2 in production, set OBJECT_STORAGE_PROFILE=R2 and override
# the endpoint/access-key/secret/bucket. R2 expects virtual-host-style
# addressing so flip path-style off too.
#
#   OBJECT_STORAGE_PROFILE=R2
#   OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   OBJECT_STORAGE_REGION=auto
#   OBJECT_STORAGE_ACCESS_KEY=<r2-access-key>
#   OBJECT_STORAGE_SECRET_KEY=<r2-secret-key>
#   OBJECT_STORAGE_BUCKET_PRODUCTS=vnshop-products
#   OBJECT_STORAGE_PATH_STYLE=false
#
#   INVOICE_STORAGE_PROFILE=R2
#   INVOICE_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   INVOICE_STORAGE_BUCKET=vnshop-invoices
#   INVOICE_STORAGE_PATH_STYLE=false
#
# Local-dev defaults (omit or leave commented out):
# OBJECT_STORAGE_ENABLED=true
# OBJECT_STORAGE_PROFILE=MINIO
# OBJECT_STORAGE_ENDPOINT=http://minio:9000
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ACCESS_KEY=vnshop
# OBJECT_STORAGE_SECRET_KEY=vnshop123
# OBJECT_STORAGE_BUCKET_PRODUCTS=vnshop-products
# OBJECT_STORAGE_PATH_STYLE=true

# MinIO root credentials. Override these (or shadow with a docker secret) in
# any shared environment — defaults are intentionally weak local-dev values.
# MINIO_ROOT_USER=vnshop
# MINIO_ROOT_PASSWORD=vnshop123

# --- Kafka SASL/PLAIN credentials ---
KAFKA_ADMIN_PASSWORD=changeme
KAFKA_SVC_ORDER_PASSWORD=changeme
KAFKA_SVC_PAYMENT_PASSWORD=changeme
KAFKA_SVC_INVENTORY_PASSWORD=changeme
KAFKA_SVC_PRODUCT_PASSWORD=changeme
KAFKA_SVC_SHIPPING_PASSWORD=changeme
KAFKA_SVC_FINANCE_PASSWORD=changeme
KAFKA_SVC_SEARCH_PASSWORD=changeme
KAFKA_SVC_RECOMMENDATIONS_PASSWORD=changeme

# --- Elasticsearch ---
ELASTIC_PASSWORD=changeme
