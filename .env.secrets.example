# Copy to .env.secrets for local development. Never commit real secrets.
DATASOURCE_PASSWORD=replace-with-local-postgres-password
KEYCLOAK_ADMIN_PASSWORD=replace-with-local-keycloak-admin-password
GATEWAY_OAUTH2_CLIENT_SECRET=replace-with-local-gateway-client-secret
PAYMENT_GATEWAY_API_KEY=replace-with-local-payment-provider-api-key
CARRIER_API_KEY=replace-with-local-carrier-api-key
JWT_SIGNING_KEY=replace-with-local-high-entropy-jwt-signing-key

# --- Kafka SASL/PLAIN credentials ---
KAFKA_ADMIN_PASSWORD=changeme
KAFKA_SVC_ORDER_PASSWORD=changeme
KAFKA_SVC_PAYMENT_PASSWORD=changeme
KAFKA_SVC_INVENTORY_PASSWORD=changeme
KAFKA_SVC_PRODUCT_PASSWORD=changeme
KAFKA_SVC_SHIPPING_PASSWORD=changeme
KAFKA_SVC_FINANCE_PASSWORD=changeme
KAFKA_SVC_SEARCH_PASSWORD=changeme
KAFKA_SVC_RECOMMENDATIONS_PASSWORD=changeme

# Keycloak client secrets (rotate for production)
KEYCLOAK_GATEWAY_CLIENT_SECRET=<generate-strong-secret>
KEYCLOAK_ADMIN_API_CLIENT_SECRET=<generate-strong-secret>
