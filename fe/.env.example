VITE_API_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8085
VITE_KEYCLOAK_REALM=vnshop
VITE_KEYCLOAK_CLIENT_ID=vnshop-api

# Stripe Embedded Elements. Both flag + publishable key required to render
# the Stripe section on /checkout. Get sandbox keys from dashboard.stripe.com.
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=

# PayPal Smart Buttons. Both flag + client id required. Get sandbox client
# id from developer.paypal.com.
VITE_PAYPAL_ENABLED=false
VITE_PAYPAL_CLIENT_ID=
