# =============================================================================
# VNShop — Local / Sandbox Credential Template
# =============================================================================
# Copy this file to secrets.env.local and fill in your sandbox values.
# secrets.env.local is .gitignore'd and must NEVER be committed.
#
# Methods that work out of the box (no external account needed):
#   - COD       — always enabled, no credentials.
#   - VietQR    — uses vietqr.io stateless URL generator; set your bank account
#                 below. SePay sandbox is optional for auto-confirmation.
#
# Methods that require an external sandbox account (sign-up links in
# docs/payments/sandbox-setup.md):
#   - Stripe, PayPal, VNPay, MoMo, SePay
# =============================================================================

# ---------------------------------------------------------------------------
# COD — Cash on Delivery
# No credentials required. Enable/disable only.
# ---------------------------------------------------------------------------
COD_ENABLED=true

# ---------------------------------------------------------------------------
# VietQR — Bank transfer via QR code (manual admin confirmation)
# No external API key. Fill your sandbox bank account details.
# VIETQR_BANK_BIN: Vietcombank=970436, Techcombank=970407, MB=970422
#                  Full list: https://api.vietqr.io/v2/banks
# ---------------------------------------------------------------------------
VIETQR_ENABLED=true
VIETQR_BANK_BIN=970436
VIETQR_ACCOUNT_NO=1234567890
VIETQR_ACCOUNT_NAME=NGUYEN VAN A
VIETQR_TEMPLATE=compact2

# Optional: SePay sandbox for auto-confirmation of VietQR transfers.
# Set SEPAY_ENABLED=true and fill in SePay credentials below.

# ---------------------------------------------------------------------------
# SePay — Automated bank-transfer confirmation webhook
# Sign up at https://sepay.vn, create a sandbox account, then:
#   Dashboard → Tài khoản ngân hàng → copy Account ID
#   Dashboard → API Key → generate a key
# ---------------------------------------------------------------------------
SEPAY_ENABLED=false
SEPAY_API_KEY=your_sepay_api_key_here
SEPAY_ACCOUNT_ID=12345
SEPAY_BASE_URL=https://my.sepay.vn/userapi
SEPAY_POLL_INTERVAL_SECONDS=30

# ---------------------------------------------------------------------------
# Stripe — Card payments (international)
# Sign up at https://dashboard.stripe.com/register (free sandbox).
# Keys are on the Dashboard → Developers → API keys page.
# Webhook secret: run `stripe listen --forward-to localhost:8092/payment/stripe/webhook`
#   and copy the "whsec_..." printed in the terminal.
# ---------------------------------------------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ---------------------------------------------------------------------------
# PayPal — PayPal wallet / card (international)
# Sign up at https://developer.paypal.com (free sandbox).
#   My Apps & Credentials → Create App → copy Client ID and Secret.
#   Set PAYPAL_MODE=sandbox for testing.
# ---------------------------------------------------------------------------
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret_here
PAYPAL_MODE=sandbox

# ---------------------------------------------------------------------------
# VNPay — Vietnamese domestic card / internet banking
# Register a merchant at https://sandbox.vnpayment.vn/devreg
#   After approval you receive a Terminal ID (TMN Code) and Hash Secret.
# ---------------------------------------------------------------------------
VNPAY_ENABLED=false
VNPAY_TMN_CODE=your_vnpay_tmn_code_here
VNPAY_HASH_SECRET=your_vnpay_hash_secret_here
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8092/payment/vnpay/return
VNPAY_IPN_URL=http://localhost:8092/payment/vnpay/ipn

# ---------------------------------------------------------------------------
# MoMo — MoMo e-wallet (Vietnam)
# Request sandbox access at https://developers.momo.vn
#   Contact form → Tích hợp thanh toán → sandbox credentials are emailed.
#   You receive: Partner Code, Access Key, Secret Key.
# ---------------------------------------------------------------------------
MOMO_ENABLED=false
MOMO_PARTNER_CODE=your_momo_partner_code_here
MOMO_ACCESS_KEY=your_momo_access_key_here
MOMO_SECRET_KEY=your_momo_secret_key_here
MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_DR_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_REDIRECT_URL=http://localhost:8092/payment/momo/return
MOMO_IPN_URL=http://localhost:8092/payment/momo/ipn
MOMO_REQUEST_TYPE=captureWallet
MOMO_LANG=vi

# ---------------------------------------------------------------------------
# Database (payment-service)
# ---------------------------------------------------------------------------
DB_PASSWORD=vnshop

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
