    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/serve-static": "^5.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.24",
    "axios": "^1.7.9",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
