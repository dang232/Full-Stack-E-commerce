# MongoDB
MONGO_URI=mongodb://vnshop:vnshop123@localhost:27017/notification_db?authSource=admin

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD:-vnshop123}@localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Auth
KEYCLOAK_ISSUER_URI=http://localhost:8085/realms/vnshop
KEYCLOAK_JWK_SET_URI=http://localhost:8085/realms/vnshop/protocol/openid-connect/certs

# Service
PORT=8087

# Notification channels
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS=noreply@vnshop.vn
AWS_REGION=ap-southeast-1
